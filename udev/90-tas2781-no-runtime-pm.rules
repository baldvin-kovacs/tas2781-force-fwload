# Keep TAS2781 smart amplifiers out of runtime suspend.
#
# With runtime PM on "auto", the amps drop into software shutdown after a
# few seconds of silence and do not reliably come back: on the next stream
# the driver believes its DSP program/config is still current ("Unneeded
# loading dsp conf" in dmesg) and does not re-establish the amps. The
# force-fwload workaround is only reliable with the amps pinned on.
#
# Tradeoff: the amps stay powered continuously (minor battery cost).
ACTION=="add|change|bind", SUBSYSTEM=="i2c", DRIVERS=="tas2781-hda", ATTR{power/control}="on"
